# Referans: Projede zaten .env varsa onu kullanın. Kullanmadığınız servislerin satırlarını .env'den silebilirsiniz.
#
# ========== ZORUNLU ==========
PORT=3006
NODE_ENV=production
PUBLIC_APP_URL=https://yourdomain.com
APP_DOMAIN=yourdomain.com
# Frontend origin'leri (CORS). Credentials ile istek icin hepsi gerekir.
# Ornek: https://snapsell.website, https://snapsellapp-6649a.web.app
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://snapsell.website,https://snapsellapp-6649a.web.app

# Firebase (Admin SDK) – sadece Google giriş token doğrulama. Veritabanı Supabase.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Supabase – veritabanı. Dashboard > Settings > API: Project URL + keys
SUPABASE_URL=https://eabgyxssepusxceqwmta.supabase.co
# Anon key: /api/plans ve public okuma için. Service role: kullanıcı yazma/admin için.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ADMIN_PASSWORD=guclu_bir_sifre
ADMIN_EMAIL=admin@yourdomain.com
OPENAI_API_KEY=sk-...

# Abonelik webhook (ödeme varsa)
SUBSCRIPTION_WEBHOOK_SECRET=whsec_...

# ========== GÖRSEL DÜZENLEME (Görsel düzenleme sayfası için birini kullanın) ==========
# Sadece PhotoRoom kullanıyorsanız REPLICATE_* satırlarına gerek yok.
PHOTOROOM_API_KEY=

# Replicate – Sadece PhotoRoom kullanmıyorsanız (eski/alternatif akış) gerekir. Kullanmıyorsanız bu 3 satırı silin.
# REPLICATE_API_TOKEN=r8_...
# REPLICATE_ALLOWED_EMAILS=email1@example.com
# REPLICATE_BRIA_PACKSHOT_VERSION=

# ========== KULLANMIYORSANIZ .env'DEN SİLEBİLİRSİNİZ ==========
# Leonardo AI – Kodda referans var ama kullanmıyorsanız bu satırı eklemeyin/silin.
# LEONARDO_API_KEY=

# Pixian.AI – Kodda referans var ama kullanmıyorsanız bu satırları eklemeyin/silin.
# PIXIAN_API_ID=
# PIXIAN_API_SECRET=
# PIXIAN_TEST=true

# Fiyat arama (isteğe bağlı)
# SERPAPI_API_KEY=
# EXA_API_KEY=

# Demo modu (sadece test – production'da kapatın)
# PRO_PLAN_DEMO=true
