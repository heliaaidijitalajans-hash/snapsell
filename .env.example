# Referans: Projede zaten .env varsa onu kullanın. Kullanmadığınız servislerin satırlarını .env'den silebilirsiniz.
#
# ========== ZORUNLU ==========
PORT=3006
NODE_ENV=production
# Frontend URL. Production: snapsell.website
PUBLIC_APP_URL=https://snapsell.website
APP_DOMAIN=https://snapsell.website
# CORS: Frontend origin'leri (virgülle ayrılmış).
ALLOWED_ORIGINS=https://snapsell.website,https://www.snapsell.website

# Firebase (Admin SDK) – sadece Google giriş token doğrulama. Veritabanı Supabase.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Supabase – veritabanı (Dashboard > Settings > API)
SUPABASE_URL=https://eabgyxssepusxceqwmta.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
# Zorunlu (kullanıcı kaydı): Supabase Dashboard > API > service_role
SUPABASE_SERVICE_ROLE_KEY=

ADMIN_PASSWORD=guclu_bir_sifre
ADMIN_EMAIL=admin@yourdomain.com
OPENAI_API_KEY=sk-...

# ========== GÖRSEL DÜZENLEME ==========
# Vercel serverless (/api/photoroom/pipeline) ve server.js için zorunlu.
# PhotoRoom Dashboard: https://app.photoroom.com/api-dashboard (Image Editing / Plus planı)
PHOTOROOM_API_KEY=

# Replicate – Sadece PhotoRoom kullanmıyorsanız (eski/alternatif akış) gerekir. Kullanmıyorsanız bu 3 satırı silin.
# REPLICATE_API_TOKEN=r8_...
# REPLICATE_ALLOWED_EMAILS=email1@example.com
# REPLICATE_BRIA_PACKSHOT_VERSION=

# ========== KULLANMIYORSANIZ .env'DEN SİLEBİLİRSİNİZ ==========
# Leonardo AI – Kodda referans var ama kullanmıyorsanız bu satırı eklemeyin/silin.
# LEONARDO_API_KEY=

# Pixian.AI – Kodda referans var ama kullanmıyorsanız bu satırları eklemeyin/silin.
# PIXIAN_API_ID=
# PIXIAN_API_SECRET=
# PIXIAN_TEST=true

# Fiyat arama (isteğe bağlı)
# SERPAPI_API_KEY=
# EXA_API_KEY=

# Demo modu (sadece test – production'da kapatın)
# PRO_PLAN_DEMO=true
