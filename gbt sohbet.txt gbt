            { type: "image_url", image_url: { url } },
          ],
        },
      ],
    }),
  });

  const data = await response.json();
  const result = data.choices[0].message.content;

  await admin.firestore().collection("results").add({
    imageUrl: url,
    analysis: result,
    createdAt: admin.firestore.FieldValue.serverTimestamp(),
  });

  return null;
});

