{
  "name": "snapsell-app",
  "version": "1.0.0",
  "description": "SnapSell - Ürün görseli ve liste metni oluşturma",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "dev": "node server.js",
    "build": "npm run build:design",
    "deploy:firebase": "npm run build && echo. && echo [KURULUM] dist/config.json icinde apiUrl = backend URL yapin, sonra: firebase deploy && echo.",
    "build:css": "npx tailwindcss -i ./src/input.css -o ./public/css/tailwind.css --minify",
    "build:design": "npm run build --prefix saas-design-extracted",
    "postinstall": "node -e \"try { require('fs').mkdirSync('data', { recursive: true }); } catch (e) {}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^12.7.0",
    "form-data": "^4.0.5",
    "openai": "^6.22.0",
    "sharp": "^0.33.5",
    "stripe": "^20.4.1"
  }
}
