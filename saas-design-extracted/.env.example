# Build-time (Vite). Production’da mutlaka doldurun.

# Backend API – tüm /api istekleri bu adrese gider
VITE_API_BASE_URL=https://snapsell-production.up.railway.app

# Uygulama ana URL (paylaşım, yönlendirme, canonical)
VITE_APP_URL=https://www.snapsell.website

# Supabase – sadece frontend’te Supabase kullanıyorsanız doldurun.
# Supabase Dashboard > Project Settings > API: Project URL ve anon (public) key.
# Boş bırakılırsa backend yine kendi SUPABASE_* env’leri ile çalışır.
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
