{
  "installCommand": "npm install && npm install --prefix saas-design-extracted",
  "buildCommand": "npm run build",
  "outputDirectory": "saas-design-extracted/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
